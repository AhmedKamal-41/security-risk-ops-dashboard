# =============================================================================
# Vulnerability Management Pipeline — environment configuration
# -----------------------------------------------------------------------------
# Copy this file to `.env` and fill in your values:
#     cp .env.example .env
# Never commit your real `.env` file — it is gitignored.
# =============================================================================


# -----------------------------------------------------------------------------
# Database (required)
# -----------------------------------------------------------------------------
# PostgreSQL connection used by every pipeline step. All five values are
# required. Examples below assume a local Postgres 16 install.

DB_HOST=localhost
DB_PORT=5432
DB_NAME=vuln_mgmt
DB_USER=postgres
DB_PASSWORD=changeme


# -----------------------------------------------------------------------------
# NVD API key (optional)
# -----------------------------------------------------------------------------
# Get a free key here: https://nvd.nist.gov/developers/request-an-api-key
# Without a key the NVD rate limit is 5 requests per 30 seconds; with a key
# it rises to 50 requests per 30 seconds, which makes CVE ingestion
# roughly 10x faster and far less likely to hit 403/429 throttling.
# Leave blank or unset to run unauthenticated.

NVD_API_KEY=

# Number of days of CVE history to fetch. Increase for initial load.
CVE_DAYS_BACK=30


# -----------------------------------------------------------------------------
# Slack webhook (optional)
# -----------------------------------------------------------------------------
# Incoming-webhook URL used by the alerting module to post high-severity
# notifications. Create one at https://api.slack.com/messaging/webhooks.


